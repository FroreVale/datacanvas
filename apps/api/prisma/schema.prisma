generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum DatasetSourceKind {
  UPLOAD
  SEED
}

model Dataset {
  id             String           @id
  name           String
  description    String
  sourceFilename  String
  sourceKind     DatasetSourceKind
  sourcePath     String
  version        Int              @default(1)
  rowCount       Int              @default(0)
  columnsJson    Json
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  charts         Chart[]
}

model Dashboard {
  id          String   @id
  title       String
  description String
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  charts      Chart[]
}

model Chart {
  id             String    @id
  dashboardId    String
  datasetId      String
  title          String
  chartType      String
  queryJson      Json
  positionJson   Json
  ownerSessionId String
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  dashboard      Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  dataset        Dataset    @relation(fields: [datasetId], references: [id], onDelete: Restrict)
}
